// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int         @id @default(autoincrement())
  email      String      @unique
  password   String
  name       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  workspaces Workspace[]
}

model Workspace {
  id             String    @id @default(cuid())
  name           String
  userId         Int
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitors       Monitor[]
  customDomain   String?   @unique   // e.g. "status.theirclient.com"
  domainVerified Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Monitor {
  id             String         @id @default(cuid())
  workspaceId    String
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name           String
  url            String
  type           MonitorType    @default(HTTP)
  method         HttpMethod     @default(GET)
  interval       Int            @default(5)
  headers        Json?
  body           String?
  expectedStatus Int?
  expectedBody   String?
  paused         Boolean        @default(false)
  lastCheckedAt  DateTime?
  checks         MonitorCheck[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model MonitorCheck {
  id         String   @id @default(cuid())
  monitorId  String
  monitor    Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  ok         Boolean
  statusCode Int?
  responseMs Int?
  error      String?
  startedAt  DateTime @default(now())  // when this up/down streak started
  checkedAt  DateTime @updatedAt        // last time a check ran in this streak
  checkCount Int      @default(1)       // how many checks are in this streak

  @@index([monitorId, startedAt(sort: Desc)])
}

enum MonitorType {
  HTTP
  TCP
}

enum HttpMethod {
  GET
  POST
  HEAD
}
